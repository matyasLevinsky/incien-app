# Data (data/raw + data/processed) IS tracked on purpose: it is extracted on a
# credentialed machine, committed, and pulled here. Only machine-local cruft is ignored.

# Local extraction cache manifest (machine-specific, regenerated by 01_extract.R)
data/raw/.extract_cache.rds

# Shinylive build output (generated by the GitHub Action, deployed to gh-pages)
docs/

# Local histogram render check (dev/render_histograms.R), not deployed
render_check/

# R session cruft
.Rhistory
.RData
.Rproj.user/

# Never commit credentials
.Renviron
